{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-meteo-darius"
		},
		"LS_ADLS_Meteo_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_Meteo'"
		},
		"LS_ADLS_Meteo_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stmeteodarius.dfs.core.windows.net/"
		},
		"LS_KeyVault_Meteo_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-meteo-darius-01.vault.azure.net/"
		},
		"LS_SQL_Meteo_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserver-darius-learn.database.windows.net"
		},
		"LS_SQL_Meteo_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-meteo-bronze"
		},
		"LS_SQL_Meteo_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "dariusadmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-meteo-darius_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_Meteo_accountKey": {
						"value": "[parameters('LS_ADLS_Meteo_accountKey')]"
					},
					"LS_ADLS_Meteo_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Meteo_properties_typeProperties_url')]"
					},
					"LS_KeyVault_Meteo_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_Meteo_properties_typeProperties_baseUrl')]"
					},
					"LS_SQL_Meteo_properties_typeProperties_server": {
						"value": "[parameters('LS_SQL_Meteo_properties_typeProperties_server')]"
					},
					"LS_SQL_Meteo_properties_typeProperties_database": {
						"value": "[parameters('LS_SQL_Meteo_properties_typeProperties_database')]"
					},
					"LS_SQL_Meteo_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQL_Meteo_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}